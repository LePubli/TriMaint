# ===== Configuration TriMaint / RefMaint =====
# Copiez ce fichier en .env et adaptez les valeurs.

# --- Base de données PostgreSQL ---
POSTGRES_DB=trimaint
POSTGRES_USER=trimaint
# Générer un mot de passe fort : openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_WITH_A_STRONG_PASSWORD

# --- Sécurité JWT ---
# OBLIGATOIRE en production. Générer avec : openssl rand -hex 32
SECRET_KEY=CHANGE_ME_WITH_64_RANDOM_CHARACTERS_MINIMUM

# --- CORS (origines séparées par virgules) ---
ALLOWED_ORIGINS=http://localhost:8080

# --- Uploads ---
MAX_UPLOAD_SIZE=10485760

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Backend performance ---
GUNICORN_WORKERS=2

# --- Bootstrap admin (optionnel) ---
# Mettre BOOTSTRAP_ADMIN=1 pour créer admin au premier démarrage
BOOTSTRAP_ADMIN=1
BOOTSTRAP_ADMIN_PASSWORD=test
BOOTSTRAP_ADMIN_EMAIL=admin@trimaint.local

# --- Rate limiting ---
LOGIN_RATE_LIMIT=5/minute

# --- Port frontend exposé sur l'hôte ---
FRONTEND_PORT=80
